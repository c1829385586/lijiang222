/* ===== 亚朵风格 - 全局样式 ===== */
page {
  background: #F7F7F7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
}

.container {
  padding: 0;
}

/* ===== 弹性布局 ===== */
.flex {
  display: flex;
  align-items: center;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ===== 卡片 ===== */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}

/* ===== 价格 ===== */
.price {
  color: #C81D2B;
  font-weight: 700;
}
.price::before {
  content: '¥';
  font-size: 22rpx;
}

/* ===== 主按钮 - 亚朵红 ===== */
.btn-primary {
  background: #C81D2B;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 22rpx 0;
  text-align: center;
  border: none;
  letter-spacing: 2rpx;
}

/* ===== 标签 ===== */
.tag {
  background: #F5F5F5;
  color: #666;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  display: inline-block;
  margin-right: 8rpx;
}

/* ===== 文字截断 ===== */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 分隔线 ===== */
.divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 0 24rpx;
}
