page {
  background: #FAF7F2;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #3D3229;
  --primary: #4A3728;
  --accent: #C8A96E;
  --accent-dark: #A68B4B;
  --bg: #FAF7F2;
  --card: #FFFCF7;
  --border: #F0EBE3;
  --text: #3D3229;
  --text-secondary: #8A7E72;
  --text-light: #B5ADA3;
  --green: #5B8C6A;
  --red: #C05040;
}

.container {
  padding: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin: 24rpx 0;
  padding: 0 24rpx;
  color: var(--primary);
  letter-spacing: 1rpx;
}

.flex {
  display: flex;
  align-items: center;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card {
  background: var(--card);
  border-radius: 24rpx;
  margin: 20rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(74,55,40,0.06);
  border: 1rpx solid rgba(200,169,110,0.12);
}

.price {
  color: var(--accent-dark);
  font-weight: 700;
}

.price::before {
  content: '¥';
  font-size: 22rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), #5C4433);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 0;
  text-align: center;
  border: none;
  letter-spacing: 2rpx;
}

.tag {
  background: rgba(200,169,110,0.12);
  color: var(--accent-dark);
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-right: 8rpx;
  letter-spacing: 1rpx;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
