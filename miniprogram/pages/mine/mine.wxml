<!--pages/mine/mine.wxml-->
<view class="mine-page">
  <!-- 顶部头像区 - 丽江度假风 -->
  <view class="mine-header">
    <view class="header-bg-decor"></view>
    <view class="mine-header-content">
      <view class="avatar-wrap">
        <image class="mine-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="avatar-ring"></view>
      </view>
      <view class="mine-user">
        <text class="mine-name">{{userInfo.nickName || '点击登录'}}</text>
        <text class="mine-slogan">丽江 · 慢生活</text>
      </view>
      <view class="member-badge" bindtap="goMember">
        <text class="member-level">{{memberLevel}}</text>
        <text class="member-points">{{memberPoints}}积分</text>
      </view>
    </view>
  </view>

  <!-- 商户入口 -->
  <view class="merchant-entry" bindtap="goMerchantCenter">
    <view class="merchant-entry-left">
      <view class="merchant-icon-wrap">
        <text class="merchant-entry-icon">🏪</text>
      </view>
      <view>
        <text class="merchant-entry-title">{{isMerchant ? '商户中心' : '我是商家'}}</text>
        <text class="merchant-entry-desc">{{isMerchant ? '管理店铺、商品和订单' : '入驻平台，开启生意'}}</text>
      </view>
    </view>
    <text class="menu-arrow">›</text>
  </view>

  <!-- 我的订单 -->
  <view class="mine-section">
    <view class="section-header" bindtap="goOrders" data-status="all">
      <text class="section-title">我的订单</text>
      <text class="section-more">全部 ›</text>
    </view>
    <view class="order-status-grid">
      <view class="order-status-item" bindtap="goOrders" data-status="pending">
        <view class="status-icon-wrap pending">
          <image class="status-icon" src="/images/mine/pending.png" mode="aspectFit"/>
        </view>
        <text class="status-name">待支付</text>
      </view>
      <view class="order-status-item" bindtap="goOrders" data-status="paid">
        <view class="status-icon-wrap paid">
          <image class="status-icon" src="/images/mine/paid.png" mode="aspectFit"/>
        </view>
        <text class="status-name">已支付</text>
      </view>
      <view class="order-status-item" bindtap="goOrders" data-status="completed">
        <view class="status-icon-wrap completed">
          <image class="status-icon" src="/images/mine/completed.png" mode="aspectFit"/>
        </view>
        <text class="status-name">已完成</text>
      </view>
      <view class="order-status-item" bindtap="goOrders" data-status="cancelled">
        <view class="status-icon-wrap cancelled">
          <image class="status-icon" src="/images/mine/cancelled.png" mode="aspectFit"/>
        </view>
        <text class="status-name">已取消</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="mine-section menu-section">
    <view class="menu-item" bindtap="goAddress">
      <view class="menu-item-left">
        <view class="menu-icon-wrap addr">
          <image class="menu-icon" src="/images/mine/address.png" mode="aspectFit"/>
        </view>
        <text class="menu-text">收货地址</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goOrders" data-status="all">
      <view class="menu-item-left">
        <view class="menu-icon-wrap order">
          <image class="menu-icon" src="/images/mine/order.png" mode="aspectFit"/>
        </view>
        <text class="menu-text">全部订单</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goCart">
      <view class="menu-item-left">
        <view class="menu-icon-wrap cart">
          <image class="menu-icon" src="/images/mine/cart.png" mode="aspectFit"/>
        </view>
        <text class="menu-text">购物车</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMyReviews">
      <view class="menu-item-left">
        <view class="menu-icon-wrap order">
          <text style="font-size:36rpx">⭐</text>
        </view>
        <text class="menu-text">我的评价</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="contactService">
      <view class="menu-item-left">
        <view class="menu-icon-wrap service">
          <image class="menu-icon" src="/images/mine/service.png" mode="aspectFit"/>
        </view>
        <text class="menu-text">联系客服</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item no-border" bindtap="goAbout">
      <view class="menu-item-left">
        <view class="menu-icon-wrap about">
          <image class="menu-icon" src="/images/mine/about.png" mode="aspectFit"/>
        </view>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="footer-decor">
    <text class="footer-text">—  丽江 · 慢生活  —</text>
  </view>
</view>
