.mine-page {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ====== 顶部头像区 - 亚朵暖木调 ====== */
.mine-header {
  background: linear-gradient(160deg, #4A3728 0%, #6B5344 35%, #8B7355 70%, var(--accent-dark) 100%);
  padding: 60rpx 36rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.header-bg-decor {
  position: absolute;
  bottom: -10rpx;
  left: 0;
  right: 0;
  height: 40rpx;
  background: var(--bg);
  border-radius: 40rpx 40rpx 0 0;
}

.mine-header-content {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar-wrap {
  position: relative;
  margin-right: 28rpx;
}

.mine-avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(200,169,110,0.5);
}

.avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(200,169,110,0.25);
}

.mine-name {
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.mine-slogan {
  color: rgba(200,169,110,0.85);
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
  letter-spacing: 3rpx;
}

/* ====== 会员徽章 ====== */
.member-badge {
  background: rgba(200,169,110,0.15);
  backdrop-filter: blur(10px);
  border-radius: 18rpx;
  padding: 14rpx 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: auto;
  border: 1rpx solid rgba(200,169,110,0.25);
}

.member-level {
  color: var(--accent);
  font-size: 24rpx;
  font-weight: 700;
}

.member-points {
  color: rgba(200,169,110,0.7);
  font-size: 20rpx;
  margin-top: 4rpx;
}

/* ====== 商户入口 ====== */
.merchant-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: -30rpx 28rpx 0;
  padding: 28rpx 28rpx;
  background: linear-gradient(135deg, var(--primary), #5C4433);
  border-radius: 22rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 10rpx 30rpx rgba(74,55,40,0.25);
}

.merchant-entry-left {
  display: flex;
  align-items: center;
}

.merchant-icon-wrap {
  width: 74rpx;
  height: 74rpx;
  background: rgba(200,169,110,0.15);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.merchant-entry-icon {
  font-size: 36rpx;
}

.merchant-entry-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  letter-spacing: 1rpx;
}

.merchant-entry-desc {
  color: rgba(200,169,110,0.65);
  font-size: 22rpx;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

.merchant-entry .menu-arrow {
  color: rgba(200,169,110,0.35);
  font-size: 36rpx;
}

/* ====== 区块通用 ====== */
.mine-section {
  margin: 24rpx 28rpx;
  background: var(--card);
  border-radius: 22rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(74,55,40,0.05);
  border: 1rpx solid rgba(200,169,110,0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 1rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--text-light);
}

/* ====== 订单状态网格 ====== */
.order-status-grid {
  display: flex;
  justify-content: around;
  padding: 12rpx 0;
}

.order-status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.status-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.status-icon-wrap.pending { background: rgba(200,169,110,0.1); }
.status-icon-wrap.paid { background: rgba(91,140,106,0.1); }
.status-icon-wrap.completed { background: rgba(74,55,40,0.08); }
.status-icon-wrap.cancelled { background: rgba(192,80,64,0.08); }

.status-icon {
  width: 40rpx;
  height: 40rpx;
}

.status-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

/* ====== 菜单列表 ====== */
.menu-section {
  padding: 8rpx 24rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.menu-item.no-border {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
}

.menu-icon-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-wrap.addr { background: rgba(74,55,40,0.08); }
.menu-icon-wrap.order { background: rgba(200,169,110,0.1); }
.menu-icon-wrap.cart { background: rgba(91,140,106,0.1); }
.menu-icon-wrap.service { background: rgba(74,55,40,0.08); }
.menu-icon-wrap.about { background: rgba(200,169,110,0.08); }

.menu-icon {
  width: 34rpx;
  height: 34rpx;
}

.menu-text {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.menu-arrow {
  color: var(--text-light);
  font-size: 32rpx;
}

/* ====== 底部装饰 ====== */
.footer-decor {
  text-align: center;
  padding: 50rpx 0;
}

.footer-text {
  font-size: 22rpx;
  color: var(--text-light);
  letter-spacing: 6rpx;
}
