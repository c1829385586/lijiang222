.mine-page {
  background: #F7F7F7;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ===== 顶部 ===== */
.mine-header {
  background: #fff;
  padding: 40rpx 32rpx 60rpx;
}
.mine-header-content {
  display: flex;
  align-items: center;
}
.mine-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #F5F5F5;
}
.mine-name {
  color: #1A1A1A;
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}
.mine-slogan {
  color: #999;
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
}

/* ===== 商户入口 ===== */
.merchant-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: -20rpx 24rpx 0;
  padding: 24rpx 28rpx;
  background: #1A1A1A;
  border-radius: 16rpx;
  position: relative;
  z-index: 2;
}
.merchant-entry-left {
  display: flex;
  align-items: center;
}
.merchant-entry-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.merchant-entry-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}
.merchant-entry-desc {
  color: rgba(255,255,255,0.5);
  font-size: 22rpx;
  margin-top: 4rpx;
}
.merchant-entry .menu-arrow {
  color: rgba(255,255,255,0.3);
  font-size: 36rpx;
}

/* ===== 区块 ===== */
.mine-section {
  margin: 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.section-more {
  font-size: 24rpx;
  color: #999;
}

/* ===== 订单状态 ===== */
.order-status-grid {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 0;
}
.order-status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.status-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.status-icon {
  width: 44rpx;
  height: 44rpx;
}
.status-name {
  font-size: 22rpx;
  color: #666;
}

/* ===== 菜单 ===== */
.menu-section {
  padding: 8rpx 24rpx;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}
.menu-item.no-border {
  border-bottom: none;
}
.menu-item-left {
  display: flex;
  align-items: center;
}
.menu-icon-text {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 44rpx;
  text-align: center;
}
.menu-text {
  font-size: 28rpx;
  color: #1A1A1A;
}
.menu-arrow {
  color: #D9D9D9;
  font-size: 32rpx;
}

/* ===== 底部 ===== */
.footer-decor {
  text-align: center;
  padding: 40rpx 0;
}
.footer-text {
  font-size: 22rpx;
  color: #CCC;
  letter-spacing: 2rpx;
}
