/* ===== 美食列表页 ===== */
.food-page {
  background: var(--bg);
  min-height: 100vh;
}

.food-card {
  display: flex;
  background: var(--card);
  border-radius: 20rpx;
  margin: 0 24rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(74,55,40,0.06);
  border: 1rpx solid rgba(200,169,110,0.08);
}

.food-img {
  width: 230rpx;
  height: 210rpx;
  flex-shrink: 0;
}

.food-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.food-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin: 8rpx 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.food-price-label {
  font-size: 20rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

.food-distance {
  font-size: 22rpx;
  color: var(--text-light);
}

.food-score {
  font-size: 22rpx;
  color: var(--accent-dark);
  margin-right: 8rpx;
  font-weight: 600;
}
