/* ===== 美食列表页 ===== */
.food-page {
  background: #F7F7F7;
  min-height: 100vh;
}

.food-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 0 24rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  border: 1rpx solid #F5F5F5;
}

.food-img {
  width: 230rpx;
  height: 210rpx;
  flex-shrink: 0;
}

.food-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.food-desc {
  font-size: 24rpx;
  color: #666666;
  margin: 8rpx 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.food-price-label {
  font-size: 20rpx;
  color: #999999;
  margin-left: 4rpx;
}

.food-distance {
  font-size: 22rpx;
  color: #999999;
}

.food-score {
  font-size: 22rpx;
  color: #C81D2B;
  margin-right: 8rpx;
  font-weight: 600;
}
