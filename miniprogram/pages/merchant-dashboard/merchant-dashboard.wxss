.dashboard { background: #f5f5f5; min-height: 100vh; padding-bottom: 120rpx; }
.merchant-header { background: linear-gradient(135deg, var(--primary), #34495E); padding: 30rpx; display: flex; justify-content: space-between; align-items: center; }
.merchant-name { color: #fff; font-size: 34rpx; font-weight: bold; display: block; }
.merchant-type { color: rgba(255,255,255,0.7); font-size: 24rpx; }
.merchant-status { padding: 6rpx 20rpx; border-radius: 20rpx; font-size: 22rpx; }
.merchant-status.online { background: rgba(76,217,100,0.2); color: #4CD964; }
.merchant-status.offline { background: rgba(255,255,255,0.2); color: rgba(255,255,255,0.7); }
.stats-card { background: #fff; margin: -10rpx 20rpx 0; border-radius: 16rpx; padding: 24rpx; position: relative; z-index: 1; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.stats-title { font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.stats-grid { display: flex; }
.stats-item { flex: 1; text-align: center; }
.stats-num { font-size: 40rpx; font-weight: bold; color: var(--primary); display: block; }
.stats-label { font-size: 22rpx; color: #999; }
.section { margin-top: 20rpx; padding: 0 20rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: bold; }
.section-more { font-size: 24rpx; color: #999; }
.pending-order { margin: 0 0 16rpx 0 !important; }
.order-customer { font-size: 28rpx; font-weight: bold; }
.order-time { font-size: 22rpx; color: #999; }
.order-desc { font-size: 24rpx; color: #666; margin: 8rpx 0; }
.order-bottom { margin-top: 12rpx; }
.btn-sm { padding: 8rpx 24rpx; border: 1rpx solid var(--primary); border-radius: 24rpx; font-size: 24rpx; margin-left: 12rpx; color: var(--primary); }
.btn-sm.danger { color: #FF3B30; border-color: #FF3B30; }
.quick-actions { margin-top: 20rpx; padding: 0 20rpx; }
.quick-title { font-size: 30rpx; font-weight: bold; margin-bottom: 16rpx; }
.action-grid { display: flex; flex-wrap: wrap; }
.action-item { width: 25%; display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; }
.action-icon { font-size: 44rpx; }
.action-name { font-size: 24rpx; color: #666; margin-top: 8rpx; }

/* 自定义底部导航 */
.merchant-tabbar { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; background: #fff; display: flex; align-items: center; justify-content: space-around; border-top: 1rpx solid #eee; z-index: 100; }
.tab-item { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; }
.tab-icon { font-size: 36rpx; }
.tab-text { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.tab-item.active .tab-text { color: var(--primary); font-weight: bold; }
