.hotel-detail {
  padding-bottom: 140rpx;
  background: var(--bg);
  min-height: 100vh;
}

/* ===== 轮播图 ===== */
.detail-swiper {
  height: 460rpx;
}
.detail-img {
  width: 100%;
  height: 460rpx;
}

/* ===== 基本信息 ===== */
.store-name {
  font-size: 38rpx;
  font-weight: 700;
  flex: 1;
  margin-right: 16rpx;
  color: var(--primary);
  letter-spacing: 1rpx;
}

.score-badge {
  background: linear-gradient(135deg, var(--primary), #5C4433);
  border-radius: 16rpx;
  padding: 10rpx 18rpx;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.score-big {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--accent);
}

.score-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 8rpx;
}

.score-star {
  font-size: 18rpx;
}

.score-label {
  font-size: 16rpx;
  color: rgba(200,169,110,0.9);
}

.store-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 16rpx;
}

.price-suffix {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

.store-review-count {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: 16rpx;
}

.store-tags {
  margin: 16rpx 0;
}

.store-address {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  justify-content: space-between;
}

.address-nav {
  color: var(--accent-dark);
  font-size: 24rpx;
  font-weight: 500;
}

/* ===== 卡片标题 ===== */
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 20rpx;
  color: var(--primary);
  letter-spacing: 1rpx;
}

/* ===== 特色服务 ===== */
.service-grid {
  display: flex;
  flex-wrap: wrap;
}

.service-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.service-icon {
  font-size: 44rpx;
}

.service-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}

/* ===== 房型列表 ===== */
.room-list {
  margin-top: 12rpx;
}

.room-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.room-item:last-child {
  border-bottom: none;
}

.room-img {
  width: 200rpx;
  height: 150rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.room-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.room-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.room-tags {
  display: flex;
  flex-wrap: wrap;
  margin: 10rpx 0;
}

.room-tag {
  font-size: 20rpx;
  color: var(--accent-dark);
  background: rgba(200,169,110,0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.room-desc {
  font-size: 22rpx;
  color: var(--text-light);
}

.room-stock {
  font-size: 22rpx;
  color: var(--green);
  font-weight: 500;
}

.room-stock.sold-out {
  color: var(--text-light);
}

/* ===== 周边推荐 ===== */
.scroll-h {
  white-space: nowrap;
  padding: 16rpx 0;
}

.nearby-item {
  display: inline-block;
  width: 210rpx;
  margin-right: 20rpx;
}

.nearby-img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 16rpx;
}

.nearby-name {
  font-size: 24rpx;
  display: block;
  margin-top: 10rpx;
  color: var(--text);
  font-weight: 500;
}

/* ===== 底部预订栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card);
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(74,55,40,0.08);
  border-top: 1rpx solid rgba(200,169,110,0.12);
  z-index: 100;
}

.bottom-price {
  display: flex;
  flex-direction: column;
}

.price.big {
  font-size: 44rpx;
}

.label {
  font-size: 22rpx;
  color: var(--text-light);
  letter-spacing: 1rpx;
}

/* ===== 评价模块 ===== */
.review-avg {
  font-size: 28rpx;
  color: var(--accent-dark);
  font-weight: 700;
  margin-left: 12rpx;
}

.review-count {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: 8rpx;
}

.review-more {
  font-size: 24rpx;
  color: var(--accent-dark);
  font-weight: 500;
}

.review-dist {
  margin: 20rpx 0;
}

.dist-item {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.dist-star {
  width: 60rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: right;
}

.dist-bar {
  flex: 1;
  height: 14rpx;
  background: var(--border);
  border-radius: 8rpx;
  margin: 0 14rpx;
  overflow: hidden;
}

.dist-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-dark), var(--accent));
  border-radius: 8rpx;
  transition: width 0.3s;
}

.dist-count {
  width: 44rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

.review-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.review-item:last-child {
  border-bottom: none;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.review-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  border: 2rpx solid var(--border);
}

.review-name {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 500;
}

.review-stars {
  font-size: 22rpx;
}

.review-content {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.8;
  display: block;
  margin-bottom: 10rpx;
}

.review-reply {
  background: #FAF7F2;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin: 10rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  border-left: 4rpx solid var(--accent);
}

.reply-label {
  color: var(--accent-dark);
  font-weight: 600;
}

.review-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.review-empty {
  text-align: center;
  padding: 40rpx;
  color: var(--text-light);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
