.hotel-detail {
  padding-bottom: 120rpx;
  background: #F7F7F7;
}
.detail-swiper { height: 440rpx; }
.detail-img { width: 100%; height: 440rpx; }

.store-name { font-size: 36rpx; font-weight: 700; flex: 1; margin-right: 16rpx; }
.score-badge {
  background: #C81D2B;
  border-radius: 8rpx;
  padding: 8rpx 14rpx;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
.score-big { font-size: 34rpx; font-weight: 700; color: #fff; }
.score-right { display: flex; flex-direction: column; align-items: center; margin-left: 6rpx; }
.score-star { font-size: 16rpx; }
.score-label { font-size: 14rpx; color: rgba(255,255,255,0.8); }

.store-price-row { display: flex; align-items: baseline; margin-top: 12rpx; }
.price-suffix { font-size: 22rpx; color: #999; margin-left: 4rpx; }
.store-review-count { font-size: 22rpx; color: #999; margin-left: 16rpx; }
.store-tags { margin: 12rpx 0; }
.store-address { margin-top: 12rpx; font-size: 26rpx; color: #666; justify-content: space-between; }
.address-nav { color: #C81D2B; font-size: 24rpx; }

.card-title { font-size: 30rpx; font-weight: 700; display: block; margin-bottom: 16rpx; }

.service-grid { display: flex; flex-wrap: wrap; }
.service-item { width: 25%; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0; }
.service-icon { font-size: 40rpx; }
.service-name { font-size: 22rpx; color: #666; margin-top: 8rpx; }

.room-list { margin-top: 8rpx; }
.room-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.room-item:last-child { border-bottom: none; }
.room-img { width: 180rpx; height: 130rpx; border-radius: 8rpx; flex-shrink: 0; }
.room-info { flex: 1; margin-left: 16rpx; display: flex; flex-direction: column; justify-content: space-between; }
.room-name { font-size: 28rpx; font-weight: 600; }
.room-tags { display: flex; flex-wrap: wrap; margin: 8rpx 0; }
.room-tag {
  font-size: 20rpx;
  color: #C81D2B;
  background: #FFF0F0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
}
.room-desc { font-size: 22rpx; color: #999; }
.room-stock { font-size: 22rpx; color: #4CD964; }
.room-stock.sold-out { color: #999; }

.scroll-h { white-space: nowrap; padding: 12rpx 0; }
.nearby-item { display: inline-block; width: 200rpx; margin-right: 16rpx; }
.nearby-img { width: 200rpx; height: 200rpx; border-radius: 12rpx; }
.nearby-name { font-size: 24rpx; display: block; margin-top: 8rpx; }

/* 底部预订栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.bottom-price { display: flex; flex-direction: column; }
.price.big { font-size: 40rpx; }
.label { font-size: 22rpx; color: #999; }

/* 评价模块 */
.review-avg { font-size: 26rpx; color: #C81D2B; font-weight: 700; margin-left: 12rpx; }
.review-count { font-size: 22rpx; color: #999; margin-left: 8rpx; }
.review-more { font-size: 24rpx; color: #C81D2B; }
.review-dist { margin: 16rpx 0; }
.dist-item { display: flex; align-items: center; margin-bottom: 8rpx; }
.dist-star { width: 60rpx; font-size: 22rpx; color: #666; text-align: right; }
.dist-bar { flex: 1; height: 12rpx; background: #F0F0F0; border-radius: 6rpx; margin: 0 12rpx; overflow: hidden; }
.dist-fill { height: 100%; background: #C81D2B; border-radius: 6rpx; }
.dist-count { width: 40rpx; font-size: 22rpx; color: #999; }

.review-item { padding: 20rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.review-item:last-child { border-bottom: none; }
.review-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.review-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; margin-right: 12rpx; }
.review-name { font-size: 26rpx; color: #333; }
.review-stars { font-size: 22rpx; }
.review-content { font-size: 26rpx; color: #333; line-height: 1.6; display: block; margin-bottom: 8rpx; }
.review-reply { background: #F5F5F5; border-radius: 8rpx; padding: 12rpx 16rpx; margin: 8rpx 0; font-size: 24rpx; color: #666; }
.reply-label { color: #C81D2B; font-weight: bold; }
.review-time { font-size: 22rpx; color: #CCC; }
.review-empty { text-align: center; padding: 30rpx; color: #CCC; font-size: 24rpx; }
