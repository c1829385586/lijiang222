<!--pages/hotel-detail/hotel-detail.wxml-->
<view class="hotel-detail">
  <!-- 轮播图 -->
  <swiper class="detail-swiper" indicator-dots>
    <swiper-item wx:for="{{store.images}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFill" class="detail-img" bindtap="previewImage" data-urls="{{store.images}}" data-current="{{index}}"/>
    </swiper-item>
  </swiper>

  <!-- 基本信息 -->
  <view class="card">
    <view class="flex-between">
      <text class="store-name">{{store.name}}</text>
      <view class="score-badge" wx:if="{{store.score}}">
        <text class="score-big">{{store.score}}</text>
        <view class="score-right">
          <text class="score-star">⭐</text>
          <text class="score-label">好评</text>
        </view>
      </view>
    </view>
    <view class="store-price-row">
      <text class="price">{{store.minPrice}}</text>
      <text class="price-suffix">起</text>
      <text class="store-review-count" wx:if="{{reviewStats.total}}">{{reviewStats.total}}条评价</text>
    </view>
    <view class="store-tags" wx:if="{{store.tags}}">
      <text class="tag" wx:for="{{store.tags}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="store-address flex" bindtap="openMap">
      <text>📍 {{store.address}}</text>
      <text class="address-nav">导航 ></text>
    </view>
  </view>

  <!-- 特色服务 -->
  <view class="card">
    <text class="card-title">特色服务</text>
    <view class="service-grid">
      <view class="service-item" wx:for="{{store.services || defaultServices}}" wx:key="*this">
        <text class="service-icon">{{item.icon}}</text>
        <text class="service-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 房型列表 -->
  <view class="card">
    <text class="card-title">可选房型</text>
    <view class="room-list">
      <view class="room-item" wx:for="{{rooms}}" wx:key="_id" bindtap="selectRoom" data-room="{{item}}">
        <image class="room-img" src="{{item.image}}" mode="aspectFill"/>
        <view class="room-info">
          <text class="room-name">{{item.name}}</text>
          <view class="room-tags">
            <text class="room-tag" wx:if="{{item.floor}}">{{item.floor}}层</text>
            <text class="room-tag" wx:if="{{item.orientation}}">{{item.orientation}}</text>
            <text class="room-tag" wx:if="{{item.area}}">{{item.area}}㎡</text>
            <text class="room-tag" wx:if="{{item.bedType}}">{{item.bedType}}</text>
          </view>
          <text class="room-desc">{{item.description}}</text>
          <view class="flex-between">
            <text class="price">{{item.price}}</text>
            <view class="flex">
              <text class="room-stock" wx:if="{{item.stock > 0}}">剩余{{item.stock}}间</text>
              <text class="room-stock sold-out" wx:else>已满房</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ⭐ 用户评价 -->
  <view class="card">
    <view class="flex-between">
      <view class="flex">
        <text class="card-title">用户评价</text>
        <text class="review-avg" wx:if="{{reviewStats.avgRating}}">{{reviewStats.avgRating}}⭐</text>
        <text class="review-count" wx:if="{{reviewStats.total}}">({{reviewStats.total}}条)</text>
      </view>
      <text class="review-more" bindtap="goReviews" wx:if="{{reviewStats.total > 3}}">查看全部 ></text>
    </view>
    <!-- 评分分布 -->
    <view class="review-dist" wx:if="{{reviewStats.total > 0}}">
      <view class="dist-item" wx:for="{{distList}}" wx:key="star">
        <text class="dist-star">{{item.star}}星</text>
        <view class="dist-bar"><view class="dist-fill" style="width:{{item.percent}}%"></view></view>
        <text class="dist-count">{{item.count}}</text>
      </view>
    </view>
    <!-- 最新评价 -->
    <view class="review-list" wx:if="{{reviews.length}}">
      <view class="review-item" wx:for="{{reviews}}" wx:key="_id">
        <view class="review-header">
          <view class="flex">
            <image class="review-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <text class="review-name">{{item.nickName || '匿名用户'}}</text>
          </view>
          <text class="review-stars">{{item.stars}}</text>
        </view>
        <text class="review-content">{{item.content}}</text>
        <view class="review-reply" wx:if="{{item.reply}}">
          <text class="reply-label">商家回复：</text>
          <text>{{item.reply}}</text>
        </view>
        <text class="review-time">{{item.createdAt}}</text>
      </view>
    </view>
    <view class="review-empty" wx:if="{{reviews.length === 0 && reviewLoading === false}}">
      <text>暂无评价，成为第一个评价的人吧</text>
    </view>
  </view>

  <!-- 周边美食/特产（送到房间） -->
  <view class="card">
    <text class="card-title">🍜 周边美食送到房间</text>
    <scroll-view scroll-x class="scroll-h">
      <view class="nearby-item" wx:for="{{nearbyFoods}}" wx:key="_id">
        <image class="nearby-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <text class="nearby-name ellipsis">{{item.name}}</text>
        <text class="price">{{item.price}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="card">
    <text class="card-title">🎁 特产零食送到房间</text>
    <scroll-view scroll-x class="scroll-h">
      <view class="nearby-item" wx:for="{{nearbyProducts}}" wx:key="_id">
        <image class="nearby-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <text class="nearby-name ellipsis">{{item.name}}</text>
        <text class="price">{{item.price}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 底部预订栏 -->
  <view class="bottom-bar">
    <view class="bottom-price">
      <text class="label">总价</text>
      <text class="price big">{{totalPrice || '---'}}</text>
    </view>
    <view class="btn-primary" bindtap="onBookNow">立即预订</view>
  </view>
</view>
