<!--pages/cart/cart.wxml-->
<view class="cart-page">
  <view class="cart-list" wx:if="{{cartItems.length}}">
    <view class="cart-item card" wx:for="{{cartItems}}" wx:key="_id">
      <view class="flex">
        <checkbox checked="{{item.checked}}" bindchange="toggleItem" data-index="{{index}}" color="#C8A96E"/>
        <image class="cart-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <view class="cart-info">
          <text class="cart-name ellipsis">{{item.name}}</text>
          <text class="cart-desc" wx:if="{{item.canDeliverToRoom}}">🏨送到房间</text>
          <view class="flex-between">
            <text class="price">{{item.price}}</text>
            <view class="qty-control">
              <text class="qty-btn" bindtap="decrease" data-index="{{index}}">-</text>
              <text class="qty-num">{{item.quantity}}</text>
              <text class="qty-btn" bindtap="increase" data-index="{{index}}">+</text>
            </view>
          </view>
        </view>
      </view>
      <text class="cart-delete" bindtap="removeItem" data-index="{{index}}">删除</text>
    </view>
  </view>

  <view class="empty" wx:if="{{!cartItems.length}}">
    <text class="empty-icon">🛒</text><text class="empty-text">购物车空空如也</text>
  </view>

  <view class="cart-bottom" wx:if="{{cartItems.length}}">
    <view class="flex">
      <checkbox checked="{{allChecked}}" bindchange="toggleAll" color="#C8A96E"/>
      <text>全选</text>
    </view>
    <view class="flex">
      <text>合计: <text class="price">{{totalPrice}}</text></text>
      <view class="btn-primary cart-buy" bindtap="onCheckout">去结算({{checkedCount}})</view>
    </view>
  </view>
</view>
