.login-page { background: #f5f5f5; min-height: 100vh; padding-bottom: 40rpx; }
.login-header { background: linear-gradient(135deg, #1A1A1A, #34495E); padding: 60rpx 30rpx 40rpx; text-align: center; }
.login-title { color: #fff; font-size: 40rpx; font-weight: bold; display: block; }
.login-subtitle { color: rgba(255,255,255,0.7); font-size: 26rpx; }
.form-card { margin: -20rpx 20rpx 0; background: #fff; border-radius: 16rpx; padding: 30rpx; position: relative; z-index: 1; }
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 28rpx; color: #333; display: block; margin-bottom: 12rpx; }
.form-input { background: #f5f5f5; border-radius: 12rpx; padding: 0 20rpx; height: 80rpx; font-size: 28rpx; }
.form-picker { background: #f5f5f5; border-radius: 12rpx; padding: 0 20rpx; height: 80rpx; font-size: 28rpx; display: flex; align-items: center; }
.form-picker.placeholder { color: #999; }
.form-textarea { background: #f5f5f5; border-radius: 12rpx; padding: 16rpx 20rpx; width: 100%; height: 160rpx; font-size: 28rpx; box-sizing: border-box; }
.form-location { background: #f5f5f5; border-radius: 12rpx; padding: 0 20rpx; height: 80rpx; display: flex; align-items: center; justify-content: space-between; }
.form-location-placeholder { color: #999; font-size: 28rpx; }
.form-location-text { font-size: 28rpx; flex: 1; }
.form-location-icon { font-size: 32rpx; }
.upload-grid { display: flex; flex-wrap: wrap; }
.upload-item { position: relative; margin: 0 12rpx 12rpx 0; }
.upload-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.upload-delete { position: absolute; top: -10rpx; right: -10rpx; width: 36rpx; height: 36rpx; background: rgba(0,0,0,0.5); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; }
.upload-add { width: 160rpx; height: 160rpx; background: #f5f5f5; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #999; font-size: 24rpx; }
.form-agreement { display: flex; align-items: center; margin: 20rpx 0 30rpx; font-size: 24rpx; color: #666; }
.disabled { opacity: 0.5; }
