.hotel-page { background: #F7F7F7; min-height: 100vh; }

.header-bar { background: #fff; position: sticky; top: 0; z-index: 10; }
.search-wrap { padding: 16rpx 24rpx; }
.search-input { background: #F5F5F5; border-radius: 8rpx; padding: 0 24rpx; height: 72rpx; font-size: 28rpx; }
.filter-bar { display: flex; padding: 0 24rpx 16rpx; border-bottom: 1rpx solid #F0F0F0; }
.filter-item { font-size: 24rpx; color: #666; margin-right: 30rpx; padding: 8rpx 0; }
.filter-item.active { color: #C81D2B; font-weight: 600; border-bottom: 4rpx solid #C81D2B; }

.hotel-list { padding: 16rpx 0; }
.hotel-card { display: flex; background: #fff; border-radius: 16rpx; margin: 0 24rpx 16rpx; overflow: hidden; box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04); }
.hotel-img { width: 220rpx; height: 220rpx; flex-shrink: 0; }
.hotel-info { flex: 1; padding: 16rpx 20rpx; display: flex; flex-direction: column; justify-content: space-between; }
.hotel-name { font-size: 30rpx; font-weight: 600; flex: 1; margin-right: 12rpx; }
.hotel-tags { margin: 8rpx 0; }
.hotel-score-badge {
  background: #C81D2B;
  color: #fff;
  border-radius: 6rpx;
  padding: 4rpx 10rpx;
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}
.score-num { font-size: 28rpx; font-weight: 700; }
.score-label { font-size: 18rpx; margin-left: 2rpx; }
.hotel-distance { font-size: 22rpx; color: #999; }
.hotel-addr { font-size: 22rpx; color: #999; margin-bottom: 4rpx; }
.price-unit { font-size: 22rpx; }
.loading-more { text-align: center; padding: 30rpx; color: #999; font-size: 24rpx; }
