<!--pages/home/home.wxml-->
<view class="home-page">
  <!-- 顶部：定位+搜索 -->
  <view class="home-header">
    <view class="location-bar" bindtap="onChooseLocation">
      <text class="location-text ellipsis">{{locationText}}</text>
      <text class="location-arrow">▾</text>
    </view>
  </view>

  <!-- 快速预订 -->
  <view class="quick-book">
    <view class="qb-date-row">
      <view class="qb-date-item" bindtap="onQuickBookDate" data-type="checkIn">
        <text class="qb-date-label">入住</text>
        <text class="qb-date-value">{{checkInDateText}}</text>
        <text class="qb-date-day">{{checkInDay}}</text>
      </view>
      <view class="qb-nights">
        <text class="qb-nights-text">共{{nights}}晚</text>
      </view>
      <view class="qb-date-item" bindtap="onQuickBookDate" data-type="checkOut">
        <text class="qb-date-label">离店</text>
        <text class="qb-date-value">{{checkOutDateText}}</text>
        <text class="qb-date-day">{{checkOutDay}}</text>
      </view>
    </view>
    <view class="qb-search-bar" bindtap="onQuickSearch">
      <text class="qb-search-placeholder">关键字/位置/品牌</text>
      <view class="qb-search-btn">查 询</view>
    </view>
  </view>

  <!-- Banner -->
  <view class="banner-wrap" wx:if="{{banners.length}}">
    <swiper class="banner-swiper" autoplay circular indicator-dots indicator-color="rgba(0,0,0,0.2)" indicator-active-color="#C81D2B">
      <swiper-item wx:for="{{banners}}" wx:key="_id">
        <image class="banner-img" src="{{item.imageUrl}}" mode="aspectFill" bindtap="onBannerTap" data-url="{{item.linkUrl}}"/>
      </swiper-item>
    </swiper>
  </view>

  <!-- 分类入口 -->
  <view class="category-section">
    <view class="category-grid">
      <view class="category-item" wx:for="{{categories}}" wx:key="name" bindtap="onCategoryTap" data-page="{{item.page}}" data-tab="{{item.tab}}">
        <view class="category-icon-box">
          <image class="category-icon" src="{{item.icon}}" mode="aspectFit"/>
        </view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 推荐酒店 -->
  <view class="section" wx:if="{{recommendHotels.length}}">
    <view class="section-header">
      <text class="section-title">精选酒店民宿</text>
      <text class="section-more" bindtap="onCategoryTap" data-page="/pages/hotel/hotel">查看全部</text>
    </view>
    <scroll-view scroll-x class="scroll-h" enhanced show-scrollbar="{{false}}">
      <view class="hotel-card" wx:for="{{recommendHotels}}" wx:key="_id" bindtap="onHotelTap" data-id="{{item._id}}">
        <image class="hotel-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <view class="hotel-info">
          <text class="hotel-name ellipsis">{{item.name}}</text>
          <view class="hotel-tags-row">
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
          <view class="flex-between">
            <text class="price">{{item.minPrice}}</text>
            <text class="hotel-distance">{{item.distance || ''}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 推荐美食 -->
  <view class="section" wx:if="{{recommendFoods.length}}">
    <view class="section-header">
      <text class="section-title">周边美食</text>
      <text class="section-more" bindtap="onCategoryTap" data-page="/pages/food/food">查看全部</text>
    </view>
    <view class="food-list">
      <view class="food-card" wx:for="{{recommendFoods}}" wx:key="_id" bindtap="onFoodTap" data-id="{{item._id}}">
        <image class="food-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <view class="food-info">
          <text class="food-name">{{item.name}}</text>
          <text class="food-desc ellipsis">{{item.description}}</text>
          <view class="flex-between">
            <text class="price">{{item.avgPrice}}</text>
            <text class="food-distance">{{item.distance || '1.2km'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 特产零食 -->
  <view class="section" wx:if="{{recommendProducts.length}}">
    <view class="section-header">
      <text class="section-title">特产零食 · 送到房间</text>
    </view>
    <scroll-view scroll-x class="scroll-h" enhanced show-scrollbar="{{false}}">
      <view class="product-card" wx:for="{{recommendProducts}}" wx:key="_id" bindtap="onProductTap" data-id="{{item._id}}">
        <image class="product-img" src="{{item.coverImage}}" mode="aspectFill"/>
        <text class="product-name ellipsis">{{item.name}}</text>
        <view class="flex-between">
          <text class="price">{{item.price}}</text>
          <text class="product-sales">已售{{item.sales || 0}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="bottom-spacer"></view>
</view>
