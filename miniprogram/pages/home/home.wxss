/* ===== 首页 - 亚朵风格 ===== */
.home-page {
  background: #F7F7F7;
  min-height: 100vh;
}

/* ===== 顶部 ===== */
.home-header {
  background: #fff;
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.location-bar {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}
.location-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  max-width: 300rpx;
}
.location-arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}

/* ===== 快速预订 ===== */
.quick-book {
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.qb-date-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.qb-date-item {
  flex: 1;
  text-align: center;
}

.qb-date-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.qb-date-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.qb-date-day {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.qb-nights {
  padding: 0 30rpx;
  position: relative;
}
.qb-nights::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 1rpx;
  background: #E5E5E5;
  transform: translateY(-50%);
}
.qb-nights-text {
  position: relative;
  z-index: 1;
  background: #fff;
  padding: 0 8rpx;
  font-size: 24rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.qb-search-bar {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 4rpx 0 24rpx;
  height: 80rpx;
}

.qb-search-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #CCC;
}

.qb-search-btn {
  background: #C81D2B;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 6rpx;
  padding: 16rpx 36rpx;
  letter-spacing: 4rpx;
}

/* ===== Banner ===== */
.banner-wrap {
  margin: 0 24rpx 20rpx;
}
.banner-swiper {
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
}

/* ===== 分类 ===== */
.category-section {
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx 0 12rpx;
}
.category-grid {
  display: flex;
  flex-wrap: wrap;
}
.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}
.category-icon-box {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.category-icon {
  width: 56rpx;
  height: 56rpx;
}
.category-name {
  font-size: 24rpx;
  color: #333;
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 20rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx 16rpx;
  background: #F7F7F7;
}
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.section-more {
  font-size: 24rpx;
  color: #999;
}

/* ===== 酒店横滑 ===== */
.scroll-h {
  white-space: nowrap;
  padding: 0 24rpx;
}
.hotel-card {
  display: inline-block;
  width: 320rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.hotel-img {
  width: 320rpx;
  height: 210rpx;
}
.hotel-info {
  padding: 16rpx;
}
.hotel-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}
.hotel-tags-row {
  margin-bottom: 8rpx;
  min-height: 32rpx;
}
.hotel-distance {
  font-size: 22rpx;
  color: #999;
}

/* ===== 美食列表 ===== */
.food-list {
  padding: 0 24rpx;
}
.food-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.food-img {
  width: 200rpx;
  height: 180rpx;
  flex-shrink: 0;
}
.food-info {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.food-name {
  font-size: 30rpx;
  font-weight: 600;
}
.food-desc {
  font-size: 24rpx;
  color: #999;
}
.food-distance {
  font-size: 22rpx;
  color: #999;
}

/* ===== 特产横滑 ===== */
.product-card {
  display: inline-block;
  width: 220rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.product-img {
  width: 220rpx;
  height: 220rpx;
}
.product-name {
  font-size: 24rpx;
  padding: 12rpx 12rpx 0;
  display: block;
}
.product-sales {
  font-size: 20rpx;
  color: #999;
  padding-right: 12rpx;
}

.bottom-spacer {
  height: 30rpx;
}
