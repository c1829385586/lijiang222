.order-confirm {
  padding-bottom: 140rpx;
  background: var(--bg);
  min-height: 100vh;
}

.address-card {
  border-left: 6rpx solid var(--accent);
}

.addr-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-right: 16rpx;
  color: var(--text);
}

.addr-phone {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.addr-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 140rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.info-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.order-item {
  display: flex;
  align-items: center;
}

.order-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.order-info {
  flex: 1;
  margin-left: 20rpx;
}

.order-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  color: var(--text);
}

.order-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

.order-qty {
  font-size: 24rpx;
  color: var(--text-light);
}

.remark-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: var(--text);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card);
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(74,55,40,0.06);
  border-top: 1rpx solid rgba(200,169,110,0.1);
}

.bottom-price {
  display: flex;
  align-items: baseline;
}

.price.big {
  font-size: 44rpx;
}

.label {
  font-size: 22rpx;
  color: var(--text-light);
}

.disabled {
  opacity: 0.5;
}
