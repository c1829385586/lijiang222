.order-confirm {
  padding-bottom: 140rpx;
  background: #F7F7F7;
  min-height: 100vh;
}

.address-card {
  border-left: 6rpx solid #C81D2B;
}

.addr-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-right: 16rpx;
  color: #1A1A1A;
}

.addr-phone {
  font-size: 28rpx;
  color: #666666;
}

.addr-detail {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
}

.info-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
}

.order-item {
  display: flex;
  align-items: center;
}

.order-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.order-info {
  flex: 1;
  margin-left: 20rpx;
}

.order-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  color: #1A1A1A;
}

.order-desc {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-top: 4rpx;
}

.order-qty {
  font-size: 24rpx;
  color: #999999;
}

.remark-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: #1A1A1A;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.04);
  border-top: 1rpx solid #F5F5F5;
}

.bottom-price {
  display: flex;
  align-items: baseline;
}

.price.big {
  font-size: 44rpx;
}

.label {
  font-size: 22rpx;
  color: #999999;
}

.disabled {
  opacity: 0.5;
}
