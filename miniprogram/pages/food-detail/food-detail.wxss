.detail-swiper { height: 460rpx; }
.detail-img { width: 100%; height: 460rpx; }
.store-name { font-size: 38rpx; font-weight: 700; color: var(--primary); letter-spacing: 1rpx; }
.score-text { font-size: 26rpx; color: var(--accent-dark); font-weight: 600; }
.store-tags { margin: 16rpx 0; }
.store-address { margin-top: 16rpx; font-size: 26rpx; color: var(--text-secondary); justify-content: space-between; }
.address-nav { color: var(--accent-dark); font-size: 24rpx; font-weight: 500; }
.store-desc { font-size: 26rpx; color: var(--text-secondary); line-height: 1.8; }
.dish-list { margin-top: 16rpx; }
.dish-item { display: flex; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid var(--border); }
.dish-item:last-child { border-bottom: none; }
.dish-name { font-size: 28rpx; color: var(--text); font-weight: 500; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: var(--card); padding: 20rpx 28rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -4rpx 20rpx rgba(74,55,40,0.06); border-top: 1rpx solid rgba(200,169,110,0.1); }
