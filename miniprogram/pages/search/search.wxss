.search-bar { display: flex; align-items: center; padding: 16rpx 24rpx; background: #fff; position: sticky; top: 0; z-index: 10; }
.search-bar .search-input { flex: 1; background: #f5f5f5; border-radius: 36rpx; padding: 0 24rpx; height: 72rpx; font-size: 28rpx; }
.search-cancel { font-size: 28rpx; color: var(--accent-dark); margin-left: 20rpx; }

/* 分类Tab */
.type-tabs { display: flex; background: #fff; padding: 0 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.type-tab { padding: 16rpx 28rpx; font-size: 26rpx; color: #999; position: relative; }
.type-tab.active { color: var(--accent-dark); font-weight: bold; }
.type-tab.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 36rpx; height: 4rpx; background: var(--accent-dark); border-radius: 2rpx; }

/* 热门搜索 */
.hot-search { padding: 30rpx; }
.hot-tags { display: flex; flex-wrap: wrap; margin-top: 16rpx; }
.hot-tag { background: #f5f5f5; padding: 12rpx 24rpx; border-radius: 24rpx; margin: 0 16rpx 16rpx 0; font-size: 26rpx; }

/* 搜索结果 */
.result-item { display: flex; padding: 0 !important; overflow: hidden; }
.result-img { width: 180rpx; height: 180rpx; flex-shrink: 0; }
.result-info { flex: 1; padding: 16rpx; display: flex; flex-direction: column; justify-content: space-between; }
.result-name { font-size: 30rpx; font-weight: bold; }
.hot-label { font-size: 20rpx; color: var(--accent-dark); background: rgba(200,169,110,0.12); padding: 2rpx 10rpx; border-radius: 6rpx; margin-left: 10rpx; }
.result-desc { font-size: 24rpx; color: #999; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.result-type { font-size: 22rpx; color: var(--accent-dark); background: rgba(200,169,110,0.12); padding: 4rpx 12rpx; border-radius: 8rpx; }
