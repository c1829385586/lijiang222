page {
  background: #FAF7F2;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #3D3229;
  --primary: #4A3728;
  --accent: #C8A96E;
  --accent-dark: #A68B4B;
  --bg: #FAF7F2;
  --card: #FFFCF7;
  --border: #F0EBE3;
  --text: #3D3229;
  --text-secondary: #8A7E72;
  --text-light: #B5ADA3;
  --green: #5B8C6A;
  --red: #C05040;
}

.card {
  background: var(--card);
  border-radius: 24rpx;
  margin: 20rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(74,55,40,0.05);
  border: 1rpx solid rgba(200,169,110,0.08);
}

.flex { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-center { display: flex; align-items: center; justify-content: center; }

.price {
  color: var(--accent-dark);
  font-weight: 700;
}
.price::before {
  content: '¥';
  font-size: 22rpx;
  font-weight: 600;
}

.tag {
  background: rgba(200,169,110,0.1);
  color: var(--accent-dark);
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-right: 8rpx;
  letter-spacing: 1rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), #5C4433);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 0;
  text-align: center;
  border: none;
  letter-spacing: 2rpx;
}

.btn-sm {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--primary);
  color: var(--primary);
  display: inline-block;
  font-weight: 500;
}

.btn-sm.danger {
  color: var(--red);
  border-color: var(--red);
}

.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

.disabled {
  opacity: 0.5;
}
