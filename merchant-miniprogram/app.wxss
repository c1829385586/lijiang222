page {
  background: #F7F7F7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}

.flex { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-center { display: flex; align-items: center; justify-content: center; }

.price {
  color: #C81D2B;
  font-weight: 700;
}
.price::before {
  content: '¥';
  font-size: 22rpx;
}

.tag {
  background: #F5F5F5;
  color: #666;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  display: inline-block;
  margin-right: 8rpx;
}

.btn-primary {
  background: #C81D2B;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 0;
  text-align: center;
  border: none;
  letter-spacing: 2rpx;
}

.btn-sm {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  border-radius: 6rpx;
  border: 1rpx solid #C81D2B;
  color: #C81D2B;
  display: inline-block;
}
.btn-sm.danger { color: #C81D2B; border-color: #C81D2B; }

.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty { text-align: center; padding: 100rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; margin-top: 16rpx; }
.disabled { opacity: 0.5; }
