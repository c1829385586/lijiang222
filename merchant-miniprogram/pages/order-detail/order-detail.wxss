.order-detail-page { padding-bottom: 40rpx; }
.order-no { font-size: 26rpx; color: #666; }
.order-status { font-size: 28rpx; font-weight: bold; }
.order-status.pending { color: var(--accent-dark); }
.order-status.paid { color: #4CD964; }
.order-status.completed { color: #999; }
.order-status.cancelled, .order-status.rejected { color: #ccc; }
.card-title { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.order-img { width: 120rpx; height: 120rpx; border-radius: 12rpx; flex-shrink: 0; }
.order-info { flex: 1; margin-left: 16rpx; }
.order-name { font-size: 28rpx; font-weight: bold; display: block; }
.info-row { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 26rpx; }
.info-row:last-child { border-bottom: none; }
.info-label { width: 140rpx; color: #999; }
.addr-info { font-size: 26rpx; display: block; }
.addr-detail { font-size: 24rpx; color: #666; display: block; margin-top: 8rpx; }
.order-time { font-size: 24rpx; color: #999; }
.detail-actions { display: flex; padding: 20rpx; gap: 16rpx; }
.detail-actions .btn-primary, .detail-actions .btn-outline { flex: 1; text-align: center; padding: 20rpx; border-radius: 12rpx; font-size: 28rpx; }
.btn-outline { border: 1rpx solid var(--primary); color: var(--primary); }
