<!--pages/profile/profile.wxml-->
<view class="profile-page">
  <view class="profile-header">
    <image class="profile-avatar" src="{{merchant.images && merchant.images[0] || '/images/default-store.png'}}" mode="aspectFill"/>
    <text class="profile-name">{{merchant.name || '我的店铺'}}</text>
    <text class="profile-type">{{typeMap[merchant.type] || ''}}</text>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="goStoreEdit">
      <text>🏪 店铺信息</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" wx:if="{{merchant.type === 'hotel'}}" bindtap="goRoomManage">
      <text>🛏️ 房型管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goProductManage">
      <text>📦 商品管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goStats">
      <text>📊 数据统计</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="toggleStatus">
      <text>{{merchant.status === 1 ? '🟢 营业中' : '🔴 已歇业'}}</text>
      <switch checked="{{merchant.status === 1}}" bindchange="toggleStatus" color="#1A1A1A"/>
    </view>
    <view class="menu-item" bindtap="contactSupport">
      <text>💬 联系平台客服</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="btn-logout" bindtap="logout">退出登录</view>
</view>
