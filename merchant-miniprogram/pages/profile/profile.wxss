.profile-page { background: #f5f5f5; min-height: 100vh; }
.profile-header { background: linear-gradient(135deg, #1A1A1A, #34495E); padding: 40rpx; text-align: center; }
.profile-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; border: 4rpx solid #fff; }
.profile-name { color: #fff; font-size: 34rpx; font-weight: bold; display: block; margin-top: 16rpx; }
.profile-type { color: rgba(255,255,255,0.7); font-size: 24rpx; }
.menu-card { }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 28rpx; }
.menu-item:last-child { border-bottom: none; }
.menu-arrow { color: #ccc; }
.btn-logout { margin: 40rpx 20rpx; background: #fff; color: #FF3B30; text-align: center; padding: 24rpx; border-radius: 16rpx; font-size: 30rpx; }
